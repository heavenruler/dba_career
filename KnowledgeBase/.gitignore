# 排除 collector 目錄下的所有 PDF 檔案
collector/*.pdf
collector/*.md
collector/*.tsv
collector/*_tmp/
collector/.wrangler/

# 一般性的 PDF 檔案排除（可選）
*.pdf

# 系統檔案
.DS_Store
Thumbs.db

# 編輯器檔案
.vscode/
.idea/
*.swp
*.swo
*~

# 日誌檔案
*.log

# 可重建的知識庫產物
generated/
collector/imported/

# 暫存檔案
*.tmp
*.temp

# todo.sh runtime state（filter 進度紀錄；可重建：每次 filter 完成自動 append）
.todo.state
todo.pid
todo.out
