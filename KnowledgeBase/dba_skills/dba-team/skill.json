{
  "schema_version": "1.0",
  "name": "dba-team",
  "display_name": "DBA Team",
  "version": "0.1.0",
  "description": "Enterprise DBA Team multi-expert skill for OpenCode, focused on database architecture, operations, troubleshooting, migration, documentation, and memory-driven collaboration.",
  "primary_language": "zh-TW",
  "secondary_languages": [
    "en"
  ],
  "entrypoint": {
    "default_role": "dba-assistant",
    "prompt_file": "prompts/dba-assistant.md"
  },
  "files": {
    "skill_spec": "SKILL.md",
    "memory_spec": "memory.md",
    "workflow_spec": "workflows.md",
    "references_root": "references",
    "memory_root": "memory"
  },
  "capabilities": [
    "database-selection",
    "architecture-design",
    "sql-tuning",
    "ha-dr-planning",
    "operations-runbook",
    "incident-troubleshooting",
    "migration-upgrade-poc",
    "documentation-generation",
    "multi-expert-routing",
    "memory-aware-response"
  ],
  "routing": {
