    {
        "type": "text",
        "text": "\u817e\u8baf\u4e91\u5f00\u53d1\u8005\n\u817e\u8baf\u4e91\u5b98\u65b9\u793e\u533a\u516c\u4f17\u53f7\uff0c\u6c47\u805a\u6280\u672f\u5f00\u53d1\u8005\u7fa4\u4f53\uff0c\u5206\u4eab\u6280\u672f\u5e72\u8d27\uff0c\u6253\u9020\u6280\u672f\u5f71\u54cd\u529b\u4ea4\u6d41\u793e\u533a\u3002\n925\u7bc7\u539f\u521b\u5185\u5bb9\n\u516c\u4f17\u53f7\n\u67b6\u6784\u56fe 1 \u67b6\u6784\u5e08 5\n\u4fee\u6539\u4e8e 2024\u5e7408\u670827\u65e5",
