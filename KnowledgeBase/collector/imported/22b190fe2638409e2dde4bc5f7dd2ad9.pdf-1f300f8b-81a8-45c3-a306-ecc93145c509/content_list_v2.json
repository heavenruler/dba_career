    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "\u9664\u4e86\u5197\u4f59\u6a21\u5f0f\uff0c\u4e5f\u5c31\u662f\u7b80\u5355\u6765\u8bf4\u7684\u2f00\u4efd\u6570\u636e\u6709\u2f0f\u4e2a\u526f\u672c\u4e4b\u5916\uff0c ASM \u8fd8\u4f1a\u5c06\u78c1\u76d8\u7ec4\u5185\u7684\u78c1\u76d8\u6761\u5e26\u5316\n\u4ee5\u63d0\u5347\u6027\u80fd\uff0c\u8fd9\u6837\u53ef\u4ee5\u6700\u2f24\u5316\u5229\u2f64\u5171\u4eab\u5b58\u50a8\u7684\u6027\u80fd\u3002\u8fd9\u65f6\u5019 Oracle RAC \u96c6\u7fa4\u7684\u6027\u80fd\u4e0a\u9650\u5f80\u5f80\u4f9d\u8d56\n\u4e8e\u5171\u4eab\u5b58\u50a8\u7684\u6027\u80fd\uff0c\u56fd\u4ea7\u6570\u636e\u5e93\u4e2d\u7c7b\u4f3c\u7684\u67b6\u6784\u8fd8\u6709\u2fa6\u4ed3\u6570\u636e\u5e93\u7684 KES RAC \u3001\u8fbe\u68a6\u6570\u636e\u5e93\u7684 DSC \u3001\n\u5d16\u2f2d\u6570\u636e\u5e93\u7684 YAC \u3001 PolarDB \u7684\u5b58\u7b97\u5206\u79bb\u67b6\u6784\u7b49\u3002\n\uff08KES RAC\uff09\n\uff08DM DSC\uff09\n2025/6/4 \u51cc\u6668 12:37 \u4e0d\u540c\u6570\u636e\u5e93\u7684\u5b58\u7b97\u5206\u79bb\u6709\u4f55\u4e0d\u540c\nhttps://mp.weixin.qq.com/s/MLHamGiq9h\ufb01iBp4S9P6Tw 3/8"
                    }
                ]
            },
            "bbox": [
                0,
