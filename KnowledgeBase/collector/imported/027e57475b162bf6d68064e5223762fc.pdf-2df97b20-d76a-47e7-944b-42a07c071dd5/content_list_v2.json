                    {
                        "type": "text",
                        "content": "\u4f18\u79c0\u67b6\u6784\u5e08 \u00b7 \u76ee\u5f55\n\u4e0a\u4e00\u7bc7 \u4e0b\u4e00\u7bc7\n\u4f18\u79c0\u67b6\u6784\u5e08\u7684\u7b2c\u4e00\u6027\u539f\u7406\uff1a\u7a7f\u900f\u6280\u672f\u8ff7\u96fe\u7684\u672c \u4f18\u79c0\u67b6\u6784\u5e08\u7684\u6301\u7eed\u5b66\u4e60\u673a\u5236\uff1a\u5bf9\u6297\u6280\u672f\u71b5\u589e\u7684\n\u8d28\u601d\u8003 \u751f\u5b58\u6cd5\u5219"
                    }
