        ],
        "page_idx": 3
    },
    {
        "type": "text",
        "text": "\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u2f00\u7ad9\u5f0f\u5e94\u5bf9\uff1a\n1. \u6570\u636e\u5f3a\u2f00\u81f4\uff1a\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u91c7\u2f64\u591a\u6570\u6d3e\u534f\u8bae\uff0c\u9ed8\u8ba4\u7684\u4e09\u526f\u672c\u914d\u7f6e\uff0c\u6570\u636e\u5f3a\u2f00\u81f4\u540c\u6b65\uff0c\u5f7b\n\u5e95\u7684\u89e3\u51b3\u4e86\u6570\u636e\u5f3a\u2f00\u81f4\u6027\u7684\u95ee\u9898\u3002\n2. \u4e1a\u52a1\u2f46\u4fb5\u5165\uff1a\u5728\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u4e2d\uff0c\u4e1a\u52a1\u5f00\u53d1\u8005\u5b8c\u5168\u56de\u5f52 MySQL  \u5355\u673a\u5f00\u53d1\u4f53\u9a8c\uff0c\u6570\u636e\n\u53ef\u4ee5\u4efb\u610f\u7ef4\u5ea6\u5206\u6790\uff0c\u2f46\u9700\u727a\u7272\u4efb\u4f55\u4e5f\u8bb8\u9700\u6c42\u6216\u5f15\u5165\u66f4\u591a\u6280\u672f\u6808\u3002\n3. TB\uff5ePB \u7ea7\u522b\u6570\u636e\u627f\u8f7d\u80fd\u2f12\uff1a\u539f\u2f63\u6570\u636e\u5e93\u51ed\u501f\u7740\u7ec6\u7c92\u5ea6\u7684\u6570\u636e\u5b58\u50a8\u5355\u4f4d\uff0c\u5f3a\u2f24\u7684\u6570\u636e\u7ba1\u7406\n\u53ca\u8c03\u5ea6\u80fd\u2f12\uff0c\u5145\u5206\u5229\u2f64\u2f24\u6570\u636e\u4e0b\u591a\u70b9\u8ba1\u7b97\u7684\u80fd\u2f12\uff0c\u5177\u5907\u2f40\u6491PB\u7ea7\u522b\u6570\u636e\u91cf\u627f\u8f7d\u4ee5\u53ca\u4e1a\u52a1\u7a33\u5b9a\n\u6027\u4fdd\u969c\u80fd\u2f12\u3002\n4. \u2fbc\u541e\u5410\u80fd\u2f12 & \u591a\u70b9\u8bfb\u5199\u80fd\u2f12\uff1a\u5bf9\u4e8e\u6570\u636e\u5e93\u591a\u70b9\u8bfb\u5199\u662f\u2f00\u4e2a\u7a00\u7f3a\u7684\u80fd\u2f12\uff0c\u91c7\u2f64\u5b58\u7b97\u5206\u79bb\u7684\u539f\n\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u4ee5\u66f4\u2f29\u7684\u5355\u4f4d\u4e3a\u5b58\u50a8\u5355\u4f4d\uff0c\u53ef\u5145\u5206\u53d1\u6325\u6570\u636e\u5e93\u591a\u70b9\u8bfb\u5199\u80fd\u2f12\uff0c\u4ee5\u9002\u5e94\u2fbc\u541e\u5410\u573a\n\u666f\u3002\u5c24\u5176\u5728 DTC \u573a\u666f\uff0c\u5982\u4e92\u8054\u2f79\u3001\u96f6\u552e\u3001\u516c\u5171\u4e8b\u4e1a\u8fd9\u7c7b\u76f4\u63a5\u2faf\u5411\u6700\u7ec8\u2f64\u6237\u7684\u573a\u666f\u4e0b\uff0c\u539f\u2f63\u5206\n\u5e03\u5f0f\u6570\u636e\u5e93\u53ef\u4ee5\u5145\u5206\u5229\u2f64\u5206\u5e03\u5f0f\u7684\u591a\u70b9\u5199\u5165\u80fd\u2f12\u6765\u6ee1\u2f9c\u4e1a\u52a1\u6781\u2fbc\u541e\u5410\u7684\u8981\u6c42\u3002\n5. \u2fbc\u53ef\u2f64\uff1a\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u91c7\u2f64\u7684\u591a\u6570\u6d3e\u534f\u8bae\uff0c\u539f\u2f63\u5177\u5907\u6545\u969c\u2f83\u6108\u3001\u6545\u969c\u8f6c\u79fb\u3001\u6570\u636e\u526f\u672c\n\u2f83\u52a8\u8865\u5145\u7b49\u80fd\u2f12\uff0c\u5bf9\u2f64\u6237\u63d0\u4f9b\u4e86\u66f4\u53cb\u597d\u66f4\u53ef\u9760\u7684\u2fbc\u53ef\u2f64\u80fd\u2f12\u3002\n6. \u6a2a\u5411\u6269\u5c55\u80fd\u2f12\uff1a\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u53ef\u6309\u9700\u9488\u5bf9\u8ba1\u7b97\u6216\u5b58\u50a8\u53bb\u6269\u5bb9\uff0c\u4e14\u53ef\u968f\u610f\u6570\u91cf\u7684\u6269\u5c55\uff0c\n\u6bd4\u5982\u2f00\u6b21\u53ea\u6269\u5c55\u2f00\u4e2a 8c16G \u914d\u7f6e\u7684\u5b58\u50a8\u5b9e\u4f8b\u3002\u2f00\u2f8f\u547d\u4ee4\u5b8c\u6210\u6269\u5c55\uff0c\u2f46\u9700\u4efb\u4f55\u7684\u2f08\u2f2f\u2f32\u9884\u3002\n7. \u590d\u6742 SQL  \u67e5\u8be2\u80fd\u2f12\u5f3a\uff1a\u539f\u2f63\u5206\u5e03\u5f0f\u6570\u636e\u5e93\u5145\u5206\u5229\u2f64\u5206\u5e03\u5f0f\u7684\u67b6\u6784\u4ee5\u53ca\u80fd\u2f12\uff0c\u5c06\u2f8f\u5217\u53cc\u5f15\u64ce\n\u7269\u7406\u9694\u79bb\uff0c\u5217\u5f15\u64ce\u5177\u5907 MPP \u8ba1\u7b97\u80fd\u2f12\uff0c\u8ba9\u6570\u636e\u5e93\u62e5\u6709\u4e86\u63a5\u8fd1\u4f20\u7edf O L AP \u6570\u636e\u5e93\u7684\u590d\u6742 SQL\n\u5904\u7406\u6548\u7387\u548c\u80fd\u2f12\u3002\n\uff08\u2f00\uff09\u4f01\u4e1a\u5b9e\u2f12\n1. \u4ee3\u7801\u2f83\u4e3b\u53ef\u63a7\u7387\uff1a\u6838\u2f3c\u2f83\u4e3b\u53ef\u63a7\u7387\uff0c\u2f63\u6001\u2f2f\u5177\u2f83\u4e3b\u53ef\u63a7\u7387\uff0c\u662f\u5426\u80fd\u771f\u6b63\u638c\u63e1\u4ea7\u54c1\u6838\u2f3c\u4ee3\u7801\n2. \u4f01\u4e1a\u8d44\u672c\u89c4\u6a21\uff1a\u4f01\u4e1a\u7684\u8d44\u4ea7\u89c4\u6a21\uff0c\u4f01\u4e1a\u7684\u80cc\u666f\n3. \u7814\u53d1\u2f12\u91cf\u6295\u5165\uff1a\u7814\u53d1\u5b9e\u2f12\uff0c\u6570\u636e\u5e93\u4ea7\u54c1\u6295\u5165\u2f12\u5ea6\n4. \u539f\u2f1a\u2f2f\u7a0b\u5e08\u6570\u91cf\uff1a\u539f\u2f1a\u552e\u524d\u552e\u540e\u2f2f\u7a0b\u5e08\u6570\u91cf\n\uff08\u2f06\uff09\u5e02\u573a\u8ba4\u53ef\n1. \u4ea7\u54c1\u4e0b\u8f7d\u91cf\u3001\u88c5\u673a\u91cf\u3001\u5e02\u573a\u5173\u6ce8\u5ea6\n2. \u540c\u4e1a\u6848\u4f8b\uff1a\u540c\u4e1a\u6838\u2f3c\u7cfb\u7edf\u6848\u4f8b\u6570\u91cf\uff0c\u5e02\u573a\u8ba4\u53ef\u5ea6\n3. \u540c\u4e1a\u8c03\u7814\uff1a\u540c\u4e1a\u2f00\u822c\u7cfb\u7edf\u6848\u4f8b\u6570\u91cf\uff0c\u540c\u4e1a\u8c03\u7814\u8ba4\u53ef\u5ea6\n4. \u4e09\u2f45\u8bc4\u4f30\uff1a\u6743\u5a01\u7684\u8bc4\u4f30\u673a\u6784\uff0c\u4e2d\u7acb\u7684\u7b2c\u4e09\u2f45\u8bc4\u4f30\u2f79\u7ad9\n5. \u5728\u2f8f\u4e1a\u5185\u6a2a\u5411\u5bf9\u6bd4\u60c5\u51b5\u505a\u53c2\u8003\n2025/6/4 \u51cc\u6668 12:33 \u67b6\u6784\u5e08\u5fc5\u770b\uff01\u73b0\u4ee3\u5e94\u2f64\u67b6\u6784\u53d1\u5c55\u8d8b\u52bf\u4e0e\u6570\u636e\u5e93\u9009\u578b\u5efa\u8bae\u4e28 TiDB vs MySQL \u4e13\u9898\uff08\u2f00\uff09\nhttps://mp.weixin.qq.com/s/HgvRyGjHmyW-e3HwZRBJVg 5/11",
        "bbox": [
            0,
            0,
            0,
            0
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "\uff08\u4e09\uff09\u2f63\u6001\u73af\u5883\n1. \u2f2f\u5177\u5b8c\u5584\u6027\uff1a\u76d1\u63a7\u5de1\u68c0\u2f2f\u5177\u7684\u5173\u952e\u6307\u6807\u5b8c\u5584\u6027\uff0c\u6570\u636e\u8fc1\u79fb\u2f2f\u5177\u3001\u6570\u636e\u540c\u6b65\u2f2f\u5177\u2f40\u6301\u60c5\u51b5\n2. \u2f42\u6863\u5b8c\u5584\u6027\uff1a\u5b98\u2f45\u2f42\u6863\u51c6\u786e\u6027\u3001\u5b8c\u666e\u6027\uff0c\u95ee\u9898\u77e5\u8bc6\u5e93\u7684\u5b8c\u5907\u6027\n3. \u8ba4\u8bc1\u5b8c\u5584\u6027\uff1a\u57f9\u8bad\u4f53\u7cfb\u7684\u5b8c\u6574\u6027\uff0c\u83b7\u5f97\u8bc1\u4e66\u2f08\u5458\u7684\u6570\u91cf\n4. \u8f6f\u786c\u4ef6\u517c\u5bb9\u6027\uff1a\u2f40\u6301\u56fd\u4ea7\u64cd\u4f5c\u7cfb\u7edf\u6570\u91cf\uff0c\u2f40\u6301\u56fd\u4ea7\u82af\u7247\u670d\u52a1\u5668\u6570\u91cf\n5. \u5907\u4efd\u6062\u590d\u7684\u4fbf\u6377\u6027\uff0c\u5b89\u88c5\u90e8\u7f72\u7684\u2f45\u4fbf\u6027\n6. \u793e\u533a\u2f40\u6301\uff1a\u662f\u5426\u2f83\u2f30\u6784\u5efa\u5f00\u6e90\u793e\u533a\uff0c\u662f\u5426\u4e0e\u56fd\u5185\u5916\u5f00\u6e90\u793e\u533a\u5408\u4f5c\n7. \u793e\u533a\u6d3b\u8dc3\u5ea6\uff1a\u793e\u533a\u6ce8\u518c\u2f08\u6570\uff0c\u4f01\u4e1a\u6570\u91cf\u7b49\n\uff08\u56db\uff09\u4ea7\u54c1\u5b9e\u2f12\n1. \u67b6\u6784\u5148\u8fdb\u6027\uff1a\u53ef\u9760\u6027\u3001\u53ef\u2f64\u6027\u3001\u53ef\u6a2a\u5411\u6269\u5c55\u6027\u3001\u4e91\u539f\u2f63\uff0c\u591a\u5730\u591a\u4e2d\u2f3c\u67b6\u6784\u2f40\u6301\u60c5\u51b5\n2. \u8bed\u6cd5\u517c\u5bb9\u6027\uff1a\u517c\u5bb9 MySQL \u3001PostgreSQL \u3001O racle \u8bed\u6cd5\u5176\u4e2d\u2f00\u79cd\u6216\u591a\u79cd\u8bed\u6cd5\n3. \u91c7\u8d2d\u7ef4\u4fdd\u6210\u672c\uff1a\u8f6f\u4ef6 L icense \u6210\u672c\uff0c\u6bcf\u5e74\u7ef4\u4fdd\u670d\u52a1\u6210\u672c\u76f8\u540c\u67b6\u6784\u57fa\u7840\u8bbe\u65bd\u6210\u672c\n4. \u6027\u80fd\uff1a\u9009\u5b9a\u4e1a\u52a1\u7cfb\u7edf\u8fdb\u2f8f QPS/TPS \u5bf9\u6bd4\u3001\u6a2a\u5411\u6269\u5c55\u6027\u7684\u6027\u80fd\u63d0\u5347\n5. \u4ea7\u54c1\u2f63\u547d\u2f12\uff1a\u4ea7\u54c1\u662f\u5426\u5177\u5907\u4e0d\u65ad\u8fed\u4ee3\u63d0\u5347\u80fd\u2f12\uff0c\u4ea7\u54c1\u6210\u2ed3\u80fd\u2f12\u662f\u5426\u2f9c\u591f\uff0c\u662f\u5426\u5177\u5907\u2ed3\u671f\u505a\n\u597d\u2f00\u6b3e\u6570\u636e\u5e93\u7684\u51b3\u2f3c\u548c\u5b9e\u2f12\n\u5b58\u7b97\u5206\u79bb\u7684\u4e91\u539f\u2f63\u67b6\u6784\uff0c\u2f64\u6237\u6295\u7968\u7684\u7ed3\u679c\nTiDB \u5728\u67b6\u6784\u4e0a\u9009\u62e9\u5b58\u7b97\u5206\u79bb\u7684\u4e91\u539f\u2f63\u67b6\u6784\uff0c\u5bf9\u5f00\u53d1\u8005\u63d0\u4f9b\u4e86\u6781\u81f4\u7684\u654f\u6377\u5f00\u53d1\u4f53\u9a8c\uff0c\u5bf9\u4e1a\u52a1\u63d0\n\u4f9b\u4e86\u591a\u70b9\u8bfb\u5199\u80fd\u2f12\u5e94\u5bf9\u2fbc\u541e\u5410\u573a\u666f\uff0c\u91c7\u2f64\u591a\u6570\u6d3e\u534f\u8bae\u9ed8\u8ba4\u4e09\u526f\u672c\u914d\u7f6e\uff0c\u539f\u2f63\u7684\u5177\u5907\u2fbc\u53ef\u2f64\u4ee5\u53ca\n\u6545\u969c\u2f83\u52a8\u8f6c\u79fb\u80fd\u2f12\u3002\u540c\u65f6\uff0c\u91c7\u2f64\u4e1a\u754c\u9886\u5148\u7684\u2f8f\u5217\u53cc\u5f15\u64ce\u7269\u7406\u9694\u79bb\u7684 HTAP \u67b6\u6784\uff0c\u4e3a\u2f64\u6237\u7684\u5b9e\n2025/6/4 \u51cc\u6668 12:33 \u67b6\u6784\u5e08\u5fc5\u770b\uff01\u73b0\u4ee3\u5e94\u2f64\u67b6\u6784\u53d1\u5c55\u8d8b\u52bf\u4e0e\u6570\u636e\u5e93\u9009\u578b\u5efa\u8bae\u4e28 TiDB vs MySQL \u4e13\u9898\uff08\u2f00\uff09\nhttps://mp.weixin.qq.com/s/HgvRyGjHmyW-e3HwZRBJVg 6/11",
        "bbox": [
