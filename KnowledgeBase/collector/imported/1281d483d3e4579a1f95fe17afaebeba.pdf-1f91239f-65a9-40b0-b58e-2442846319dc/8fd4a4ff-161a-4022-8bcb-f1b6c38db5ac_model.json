            "angle": 0,
            "content": "/ \u63a8\u8350 \u9605 \u8bfb /\n\u4e92\u8054\u7f51 | \u5343\u4e07\u65e5\u6d3b\u80cc\u540e\uff0cTiDB \u8d4b\u80fd\u7f8e\u67da\u6838\u5fc3\u7cfb\u7edf\u9ad8\u5e76\u53d1\u573a\u666f\u964d\u672c\u589e\u6548\n\ufff0\uf0f0 \u70b9\u51fb\u6587\u672b \u3010\u9605\u8bfb\u539f\u6587\u3011 \uff0c\u7acb\u5373\u4e0b\u8f7d\u8bd5\u7528 TiDB\uff01\n\u7528\u6237\u5b9e\u8df5 \u00b7 \u76ee\u5f55\n\u4e0a\u4e00\u7bc7 \u4e0b\u4e00\u7bc7\n\u4ece\u6d3e\u4ef6\u3001\u6536\u4ef6\u5230\u652f\u4ed8\uff1a\u4e30\u5de2\u7528 TiDB \u652f\u6301\u5168\u94fe \u65e5\u5747 3 \u4ebf\u5199\u5165\u3001\u767e TB \u7ea7\u5b58\u50a8\uff1a\u653f\u52a1\u5927\u6570\u636e\n\u8def\u6838\u5fc3\u7cfb\u7edf\u7a33\u5b9a\u9ad8\u6548\u8fd0\u4f5c \u201c\u6781\u9650\u65bd\u538b\u201d\u4e0b\u7684\u56fd\u4ea7\u6570\u636e\u5e93\u7a81\u56f4\u5b9e\u5f55\n\u9605\u8bfb\u539f\u6587"
        }
    ]
]