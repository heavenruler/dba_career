[
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "\u522b\u518d\u8ba9IT\u80cc\u9505\u4e86\uff01\u6570\u636e\u8d28\u91cf\u7684\u7b2c\u4e00\u8d23\u4efb\u4eba\u662f\u4e1a\u52a1\n\u5f20\u5fd7\u660e \u6211\u53eb\u5f20\u5fd7\u660e 2025\u5e7412\u670830\u65e5 08:00 \u5317\u4eac \u539f\u521b\n\u524d\u8a00\n\u5728\u6570\u5b57\u5316\u8f6c\u578b\u9886\u57df\uff0c\u597d\u4e66\u4e0d\u591a\uff0c \u300a\u534e\u4e3a\u6570\u636e\u4e4b\u9053\u300b \u7edd\u5bf9\u662f\u4e00\u672c\u3002\n\u534e\u4e3a\u662f\u4f20\u7edf\u4f01\u4e1a\u505a\u6570\u5b57\u5316\u8f6c\u578b\u6700\u6210\u529f\u7684\u6848\u4f8b\u4e4b\u4e00\uff0c\u8fd9\u672c\u4e66\u7531\u534e\u4e3a\u7684\u6570\u636e\u7ba1\u7406\u90e8\u64b0\u5199\uff0c\u5e72\n\u8d27\u6ee1\u6ee1\u3002\n\u4f46\u8fd9\u672c\u4e66\u5f88\u5947\u602a\uff0c\u5b83\u82b1\u8d39\u4e86\u6781\u591a\u7684\u7bc7\u5e45\uff0c\u9610\u8ff0\u4e00\u4e9b\u660e\u663e\u4f1a\u8fc7\u65f6\u7684\u5177\u4f53\u6280\u672f\uff0c\u6bd4\u5982 \u6570\u636e\u6e56\n\u548c \u6570\u636e\u5730\u56fe \uff0c\u5374\u628a\u771f\u6b63\u7684\u7cbe\u534e\uff0c\u7528\u5be5\u5be5\u6570\u7b14\u5e26\u8fc7\u3002\n\u5168\u4e66\u6700\u91cd\u8981\u7684\u51e0\u53e5\u8bdd\n\u6570\u636e\u5de5\u4f5c\u7684\u8d23\u4efb\u4e3b\u4f53\uff08Data Owner) \u662f\u4e1a\u52a1\u90e8\u95e8\u3002\n\u6570\u636e\u662f\u4e1a\u52a1\u8fd0\u8425\u7684\u4ea7\u7269\uff0c\u6570\u636e\u7684\u8d28\u91cf\u5e94\u7531\u4ea7\u751f\u6570\u636e\u7684\u4e1a\u52a1\u90e8\u95e8\u8d1f\u8d23\u3002\nIT\u90e8\u95e8\u662f\u201c\u8d4b\u80fd\u8005\u201d\u548c\u201c\u5e73\u53f0\u63d0\u4f9b\u8005\u201d\uff0c\u8d1f\u8d23\u63d0\u4f9b\u5de5\u5177\u3001\u5e73\u53f0\u548c\u4e13\u4e1a\u77e5\u8bc6\uff0c\u534f\u52a9\u4e1a\u52a1\u90e8\n\u95e8\u5c65\u884c\u5176\u6570\u636e\u8d23\u4efb\uff0c\u800c\u975e\u66ff\u4e1a\u52a1\u90e8\u95e8\u627f\u62c5\u8d23\u4efb\u3002\n\u6743\u8d23\u5229\u7edf\u4e00\u7684\u7ba1\u7406\u539f\u5219\n\u4ece\u7ba1\u7406\u4e0a\u8bf4\uff0c\u5236\u5ea6\u8bbe\u8ba1\u7684\u4e00\u4e2a\u539f\u5219\u5c31\u662f\uff1a \u6743\u3001\u8d23\u3001\u5229\u7edf\u4e00 \u3002\n\u4e1a\u52a1\u90e8\u95e8\u662f\u6570\u636e\u7684\u4f7f\u7528\u8005\uff0c\u540c\u65f6\u4e5f\u662f\u53d7\u76ca\u8005\uff0c\u6240\u4ee5\u8981\u5bf9\u6570\u636e\u8d28\u91cf\u8d1f\u8d23\u3002\n\u6211\u53eb\u5f20\u5fd7\u660e \u8d5e \u5206\u4eab \u63a8\u8350 \u5199\u7559\u8a00\n\u67d0\u516c\u53f8\u9500\u552e\u90e8\u95e8\u59d4\u6258\u6280\u672f\u90e8\uff0c\u7814\u53d1\u4e86\u9500\u552e\u63d0\u6210\u7684\u8ba1\u7b97\u5e73\u53f0\u3002\n\u7531\u4e8e\u5bf9\u63d0\u6210\u89c4\u5219\u7406\u89e3\u7684\u4e0d\u4e00\u81f4\uff0c\u5bfc\u81f4\u7ed9\u9500\u552e\u53d1\u653e\u7684\u63d0\u6210\u8d85\u51fa\u6807\u51c6\uff0c\u7ed9\u516c\u53f8\u9020\u6210\u4e86\u635f\u5931\u3002\n\u516c\u53f8\u8981\u5bf9\u8be5\u4e8b\u4ef6\u8fdb\u884c\u8ffd\u8d23\uff0c\u54ea\u4e2a\u90e8\u95e8\u5e94\u5f53\u627f\u62c5\u4e3b\u8981\u8d23\u4efb\uff1f\n\u5982\u679c\u7531\u6280\u672f\u90e8\u627f\u62c5\u4e3b\u8981\u8d23\u4efb\u3002\n\u65e2\u7136\u7c7b\u4f3c\u7684\u4e8b\u60c5\u518d\u6b21\u53d1\u751f\uff0c\u88ab\u95ee\u8d23\u7684\u8fd8\u662f\u6280\u672f\u90e8\uff0c\u90a3\u4e48\u9500\u552e\u90e8\u95e8\u5bf9\u4e8e\u9700\u6c42\u7684\u6001\u5ea6\uff0c\u53ef\u80fd\n\u8fd8\u662f\u5199\u4e00\u4e2a\u5927\u6982\uff0c\u7136\u540e\u5047\u5b9a\u5177\u4f53\u7684\u7ec6\u8282\u201c\u5c5e\u4e8e\u5e38\u8bc6\u201d\u3002\n\u5982\u679c\u662f\u4e1a\u52a1\u90e8\u95e8\u627f\u62c5\u4e3b\u8981\u8d23\u4efb\n\u4f5c\u4e3a\u7cfb\u7edf\u7684\u9700\u6c42\u65b9\uff0c\u4e1a\u52a1\u90e8\u95e8\u5177\u6709\u62d2\u7edd\u8d28\u91cf\u4e0d\u5408\u683c\u7684\u6570\u636e\u901a\u8fc7\u9a8c\u6536\u7684\u6743\u529b\u3002\n\u4e1a\u52a1\u90e8\u95e8\u6709\u8981\u6c42IT\u90e8\u95e8\u4f5c\u4e3a\u5efa\u8bbe\u65b9\uff0c\u5bf9\u8d28\u91cf\u95ee\u9898\u8fdb\u884c\u6574\u6539\u7684\u6743\u529b\u3002\n\u4e1a\u52a1\u90e8\u95e8\u6709\u5bf9IT\u90e8\u95e8\u7684\u4ea4\u4ed8\u8d28\u91cf\u8fdb\u884c\u8bc4\u4ef7\u7684\u6743\u529b\u3002"
                    }
                ]
            },
            "bbox": [
                0,
                0,
                0,
                0
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "\u4e1a\u52a1\u90e8\u95e8\u6709\u6743\u529b\u8981\u6c42IT\u90e8\u95e8\uff0c\u63d0\u4f9b\u76f8\u5e94\u7684\u6570\u636e\u8d28\u91cf\u76d1\u63a7\u5de5\u5177\uff0c\u5e2e\u52a9\u5b83\u5c65\u884c\u804c\u8d23\u3002\nIT\u90e8\u95e8\u8d23\u4efb\u5236\u7684\u5f0a\u7aef\nIT\u90e8\u95e8\u8d23\u4efb\u5236\uff0c\u662f\u6570\u636e\u8d28\u91cf\u95ee\u9898\u7684\u6839\u6e90\n\u4e1a\u52a1\u90e8\u95e8\u5c06\u81ea\u5df1\u5b9a\u4f4d\u4e3a\u201c\u63d0\u9700\u6c42\u201d\u548c\u201c\u7b49\u62a5\u8868\u201d\u7684\u7528\u6237\u3002\n\u7531\u4e8e\u65e0\u9700\u4e3a\u9519\u8bef\u540e\u679c\u8d1f\u8d23\uff0c\u4e1a\u52a1\u90e8\u95e8\u63d0\u4ea4\u7684\u9700\u6c42\u8d28\u91cf\u5c06\u4f1a\u6a21\u7cca\uff0c\u968f\u610f\uff0c\u9891\u7e41\u53d8\u66f4\u3002\nIT\u90e8\u95e8\u6ca6\u4e3a\u80cc\u9505\u4fa0\u548c\u6551\u706b\u961f\uff0c\u5de5\u4f5c\u91cd\u5fc3\u4ece\u201c\u6570\u5b57\u5316\u8d4b\u80fd\u201d\u8f6c\u5411\u201c\u81ea\u8bc1\u6e05\u767d\u201d\u3002\nIT\u90e8\u95e8\u88ab\u8feb\u6295\u5165\u5927\u91cf\u7cbe\u529b\u53bb\u201c\u7406\u89e3\u201d\u539f\u672c\u5e94\u8be5\u7531\u4e1a\u52a1\u90e8\u95e8\u660e\u786e\u5b9a\u4e49\u7684\u89c4\u5219\u3002\n\u4ece\u4e3b\u89c2\u4e0a\uff0c\u6211\u76f8\u4fe1\u4e1a\u52a1\u90e8\u95e8\u540c\u6837\u60f3\u8981\u6539\u8fdb\u6570\u636e\u8d28\u91cf\uff0c\u4f46\u5236\u5ea6\u5f80\u5f80\u51b3\u5b9a\u4e86\u7ed3\u679c\u3002\n\u5408\u7406\u7684\u804c\u8d23\u5212\u5206\u4e0e\u590d\u76d8\u673a\u5236\n\u5408\u7406\u7684\u804c\u8d23\u5212\u5206\u548c\u590d\u76d8\u6539\u8fdb\u65b9\u5f0f\n\u4e1a\u52a1\u90e8\u95e8\uff0c\u8d1f\u8d23\u201c\u505a\u4ec0\u4e48\u201d\u548c\u201c\u5bf9\u4e0d\u5bf9\u201d\uff1a\u64b0\u5199\u51c6\u786e\u7684\u4e1a\u52a1\u89c4\u5219\uff0c\u5e76\u9a8c\u8bc1\u4ea4\u4ed8\u7269\u662f\u5426\u7b26\u5408\n\u9700\u6c42\u3002\nIT\u90e8\u95e8\uff1a\u8d1f\u8d23\u201c\u600e\u4e48\u505a\u201d\u548c\u201c\u5feb\u4e0d\u5feb\u201d\uff1a\u4e25\u683c\u6309\u7167\u89c4\u5219\u8fdb\u884c\u4ee3\u7801\u5f00\u53d1\u3002\n\u5982\u679c\u4e1a\u52a1\u90e8\u95e8\u5728\u9a8c\u6536\u73af\u8282\u53d1\u73b0\u95ee\u9898\uff0c\u7acb\u523b\u62d2\u7edd\u63a5\u6536\uff0c \u5e76\u8981\u6c42IT\u90e8\u95e8\u8fdb\u884c\u6574\u6539\u3002\n\u5982\u679c\u5728\u9a8c\u6536\u73af\u8282\u6ca1\u6709\u53d1\u73b0\u95ee\u9898\uff0c\u800c\u5c06\u6709\u95ee\u9898\u7684\u6570\u636e\u5e94\u7528\u5230\u4e86\u4e1a\u52a1\u4e2d\uff0c \u4e1a\u52a1\u90e8\u95e8\u9996\u5148\u627f\u62c5\n\u4e3b\u8981\u8d23\u4efb\u3002\n\u5728\u4e4b\u540e\u7684\u590d\u76d8\u4e2d\uff0c\u5fc5\u987b\u8981\u5b9a\u4f4d\u51fa\u95ee\u9898\u7684\u8be6\u7ec6\u73af\u8282\uff0c\u5e76\u505a\u51fa\u76f8\u5e94\u7684\u6574\u6539\u3002\n\u5728\u8fd9\u4e2a\u673a\u5236\u4e0b\uff0c\u4e1a\u52a1\u90e8\u95e8\u5c06\u4f1a\u8ba4\u771f\u68b3\u7406\u4e1a\u52a1\u89c4\u5219\uff0c\u800cIT\u90e8\u95e8\u5904\u4e8e\u4e1a\u52a1\u90e8\u95e8\u7684\u8003\u6838\u4e4b\u4e0b\uff0c\n\u4e5f\u52bf\u5fc5\u4f1a\u52aa\u529b\u63d0\u5347\u4ee3\u7801\u8d28\u91cf\uff0c\u4f18\u5316\u5e73\u53f0\u5de5\u5177\u3002"
                    }
                ]
            },
            "bbox": [
                0,
                0,
                0,
                0
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "\u7ed3\u8bba\u4e0e\u5efa\u8bae\n\u5982\u679c\u4f60\u7684\u7ec4\u7ec7\uff0c\u5bf9\u4e8e\u6570\u5b57\u5316\u8f6c\u578b\u7684\u6001\u5ea6\u62b1\u7740\u4e25\u8083\u7684\u6001\u5ea6\uff0c\u5f3a\u70c8\u5efa\u8bae\u5b66\u4e60\u534e\u4e3a\u7684\u5236\n\u5ea6\uff1a \u4e1a\u52a1\u90e8\u95e8\u662f\u6570\u636e\u8d28\u91cf\u7684\u7b2c\u4e00\u8d23\u4efb\u4eba\u3002 \u8fd9\u5e76\u4e0d\u662f\u51fa\u4e8e\u6211\u4e2a\u4eba\u201c\u6280\u672f\u4eba\u201d\u7684\u80cc\u666f\uff0c\u800c\n\u662f\u7ecf\u8fc7\u5b9e\u8df5\u68c0\u9a8c\uff0c\u5207\u5b9e\u6709\u6548\u7684\u5236\u5ea6\u3002\n\u4f60\u662f\u5426\u540c\u610f\u6211\u7684\u89c2\u70b9\uff1f\n\u8bf7\u5728\u624b\u673a\u5fae\u4fe1\u767b\u5f55\u6295\u7968\n\u8c01\u5e94\u8be5\u662f\u6570\u636e\u8d28\u91cf\u7684\u7b2c\u4e00\u8d23\u4efb\u4eba \u5355\u9009\n\u5f53\u7136\u662f\u4e1a\u52a1\u90e8\u95e8\uff0c\u8c01\u53d7\u76ca\u8c01\u8d1f\u8d23\uff01 135\u7968 94.41%\n\u5fc5\u987b\u662f\u6280\u672f\u90e8\u95e8\uff0c\u4ee3\u7801\u90fd\u662f\u4f60\u5199\u7684\uff01 8\u7968 5.59%\n\u5173\u4e8e\u4f5c\u8005\n\u8d44\u6df1\u6280\u672f\u4eba\uff0c\u5916\u4f01\u9ec4\u91d1\u65f6\u4ee3\u5e78\u5b58\u8005\uff0c\u91d1\u878d\u6570\u5b57\u5316\u8df5\u884c\u8005\u3002\u5206\u4eab40+\u804c\u573a\u4eba\u8f6c\u578b\u4e4b\u8def\u548c\u4f01\n\u4e1a\u6570\u5b57\u5316\u518d\u589e\u957f\u3002\n\u626b\u7801\u52a0\u5165\u300a\u6570\u5b57\u5316\u8f6c\u578b\u5e72\u8d27\u7fa4\u300b\uff0c\u8fd9\u91cc\u662f\u6570\u5b57\u5316\u8f6c\u578b\u5b9e\u6218\u8005\u7684\u805a\u96c6\u5730\uff0c\u8fd8\u6709\u514d\u8d39\u7684AI\u63d2\u4ef6\n\u548c\u63d0\u793a\u8bcd\u53ef\u4ee5\u9886\u53d6\u3002\nai\u548c\u6570\u5b57\u5316\u8f6c\u578b \u00b7 \u76ee\u5f55\n\u4e0a\u4e00\u7bc7 \u4e0b\u4e00\u7bc7\n\u6570\u5b57\u5316\u8f6c\u578b\uff0c\u522b\u518d\u8ba9\u4e00\u628a\u624b\u201c\u6302\u5e05\u201d\u4e86 \u62d2\u7edd\u5927\u5c4f\u81ea\u55e8\uff01\u4e00\u628a\u624b\u5982\u4f55\u6210\u4e3a\u6570\u5b57\u5316\u7684\u201c\u9876\n\u7ea7\u6d88\u8d39\u8005\u201d\uff1f\n\u4fee\u6539\u4e8e 2026\u5e741\u67084\u65e5"
                    }
                ]
            },
            "bbox": [
                0,
                0,
                0,
                0
            ]
        }
    ]
]