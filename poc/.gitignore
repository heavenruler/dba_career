ansible/vars/secrets.yml

# Local one-shot backups (e.g. Makefile.bak-YYYY-MM-DD) — operator working files
*.bak-*

# Dynamically generated by Terraform — do not commit
ansible/inventory/hosts.ini

# TPC-C raw results — ignore per-run timestamp dirs, keep structure & summaries
results/cockroach-tc1/*/*/*/
results/*/*/vm/*/
results/*/*/vm-1node/*/
results/*/*/vm-1node-no-analyze/*/
results/*/*/vm-3node/*/
results/*/*/vm-3node-verify/*/
results/*/*/vm-3node-direct/*/
results/*/*/k8s-unlimit/*/
results/*/*/k8s-limit/*/
results/*/*/k8s-3node-unlimit/*/
results/*/*/k8s-3node-limit/*/
results_old/

# Audit reports generated by codex audit-prompt (local artifacts, not source of truth)
results/audit/

