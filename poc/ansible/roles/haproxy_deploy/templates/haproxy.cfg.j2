global
  daemon

defaults
  mode tcp
  # warmup 1200s + run 300s + buffer；避免 prepare / warmup / run 跑超過 30s 被 cut（2026-05-25 ybdb-haproxy-3s3r 實測）
  timeout connect 5s
  timeout client  {{ haproxy_timeout_client | default('1800s') }}
  timeout server  {{ haproxy_timeout_server | default('1800s') }}
  # keepalive：避免長 idle 期間 NAT / firewall 把 connection 丟掉
  option clitcpka
  option srvtcpka

frontend {{ haproxy_frontend | default('db') }}
  bind *:{{ haproxy_port | default(4000) }}
  default_backend db_nodes

backend db_nodes
  balance roundrobin
{% for backend in haproxy_backends.split(',') %}
  server node{{ loop.index }} {{ backend }} check inter 2s
{% endfor %}

# F-B: HTTP stats endpoint for backend health / round-robin verification.
# Separate frontend on :8404 (mode http) — TCP frontend on :{{ haproxy_port }} 不變。
# `curl -s http://<haproxy-host>:8404/stats;csv` 從 .31 直接撈 CSV，無需在 .20 裝 socat。
frontend stats
  mode http
  bind *:8404
  stats enable
  stats uri /stats
  stats refresh 10s
