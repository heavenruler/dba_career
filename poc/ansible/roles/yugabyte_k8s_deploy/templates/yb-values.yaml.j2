replicas:
  master: {{ yb_replicas.master | default(3) }}
  tserver: {{ yb_replicas.tserver | default(3) }}

storage:
  master:
    count: 1
    size: 10Gi
    storageClass: local-path
  tserver:
    count: 1
    size: 50Gi
    storageClass: local-path

resource:
  master:
    requests:
      cpu: {{ yb_resources.master.requests.cpu | default('500m') }}
      memory: {{ yb_resources.master.requests.memory | default('1Gi') }}
{% if yb_resource_limits | default(false) %}
    limits:
      cpu: "{{ yb_resources.master.limits.cpu | default('1') }}"
      memory: {{ yb_resources.master.limits.memory | default('2Gi') }}
{% endif %}
  tserver:
    requests:
      cpu: "{{ yb_resources.tserver.requests.cpu | default('1') }}"
      memory: {{ yb_resources.tserver.requests.memory | default('2Gi') }}
{% if yb_resource_limits | default(false) %}
    limits:
      cpu: "{{ yb_resources.tserver.limits.cpu | default('2') }}"
      memory: {{ yb_resources.tserver.limits.memory | default('8Gi') }}
{% endif %}

gflags:
  master:
    replication_factor: "{{ yb_gflags.master.replication_factor | default('3') }}"
  tserver:
    ysql_enable_auth: "{{ yb_gflags.tserver.ysql_enable_auth | default('false') }}"
    yb_enable_read_committed_isolation: "{{ yb_gflags.tserver.yb_enable_read_committed_isolation | default('true') }}"

## Chart 2025.2.2 does not honor fixed nodePort in serviceEndpoints.
## The role creates yb-tserver-service explicitly after helm upgrade.
serviceEndpoints: []
