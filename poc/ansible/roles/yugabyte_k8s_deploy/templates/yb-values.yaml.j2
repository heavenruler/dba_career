replicas:
  master: 3
  tserver: 3

storage:
  master:
    count: 1
    size: 10Gi
    storageClass: local-path
  tserver:
    count: 1
    size: 50Gi
    storageClass: local-path

resource:
  master:
    requests:
      cpu: 500m
      memory: 1Gi
{% if yb_resource_limits | default(false) %}
    limits:
      cpu: "1"
      memory: 2Gi
{% endif %}
  tserver:
    requests:
      cpu: "1"
      memory: 2Gi
{% if yb_resource_limits | default(false) %}
    limits:
      cpu: "2"
      memory: 4Gi
{% endif %}

gflags:
  master:
    replication_factor: "3"
  tserver:
    ysql_enable_auth: "false"

## Expose YSQL via NodePort 30005 for external TPC-C access
serviceEndpoints:
  - name: yb-tserver-service
    type: NodePort
    app: yb-tserver
    ports:
      ysql-port:
        port: 5433
        nodePort: 30005
      ycql-port:
        port: 9042
        nodePort: 30006
