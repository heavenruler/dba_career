global:
  user: tidb
  ssh_port: 22
  deploy_dir: /opt/tidb/deploy
  data_dir: /opt/tidb/data
  arch: amd64

server_configs:
  pd:
    replication.max-replicas: {{ tidb_rf | default(3) }}
{% if tidb_use_zones | default(false) %}
    replication.location-labels: ["zone"]
{% endif %}
{% if tidb_use_zones | default(false) %}
  tidb:
    labels:
      zone: "placeholder"   # overridden per-node below
  tikv:
    server.labels:
      zone: "placeholder"   # overridden per-node below
{% endif %}

pd_servers:
{% for host in groups['tidb_pd'] %}
  - host: {{ hostvars[host]['ansible_default_ipv4']['address'] }}
{% endfor %}

tidb_servers:
{% for host in groups['tidb_server'] %}
  - host: {{ hostvars[host]['ansible_default_ipv4']['address'] }}
{% if tidb_use_zones | default(false) and hostvars[host]['tidb_zone'] is defined %}
    config:
      labels:
        zone: {{ hostvars[host]['tidb_zone'] }}
{% endif %}
{% endfor %}

tikv_servers:
{% for host in groups['tidb_kv'] %}
  - host: {{ hostvars[host]['ansible_default_ipv4']['address'] }}
{% if tidb_use_zones | default(false) and hostvars[host]['tidb_zone'] is defined %}
    config:
      server.labels:
        zone: {{ hostvars[host]['tidb_zone'] }}
{% endif %}
{% endfor %}

monitoring_servers:
  - host: {{ hostvars[groups['tidb_control'][0]]['ansible_default_ipv4']['address'] }}

grafana_servers:
  - host: {{ hostvars[groups['tidb_control'][0]]['ansible_default_ipv4']['address'] }}

alertmanager_servers:
  - host: {{ hostvars[groups['tidb_control'][0]]['ansible_default_ipv4']['address'] }}
