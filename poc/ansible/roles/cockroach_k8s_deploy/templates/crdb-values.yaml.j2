## CockroachDB Helm chart values
## chart: cockroachdb/cockroachdb
## docs: https://github.com/cockroachdb/helm-charts

image:
  tag: "v26.1.4"

statefulset:
  replicas: 3
  resources:
    requests:
      cpu: "1"
      memory: 2Gi
{% if crdb_resource_limits | default(false) %}
    limits:
      cpu: "2"
      memory: 8Gi
{% endif %}

storage:
  persistentVolume:
    enabled: true
    size: 30Gi
    storageClass: local-path

## --insecure mode (對齊 VM CRDB 設定，PoC 簡化)
tls:
  enabled: false

## NodePort 對外暴露 (chart 不支援 service.public.ports.*.nodePort，
## 由 role 內 kubectl patch 設定 :30007 = SQL, :30008 = admin UI)
service:
  public:
    type: NodePort

conf:
  cluster-name: poc-crdb
  single-node: false
