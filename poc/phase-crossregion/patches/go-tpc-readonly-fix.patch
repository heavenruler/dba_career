+// beginTxReadOnly is used only by ORDER_STATUS/STOCK_LEVEL — the two TPC-C
+// transaction types that never write. lib/pq's BeginTx always sends an
+// explicit BEGIN ... READ WRITE when TxOptions.ReadOnly is the Go zero value
+// (false), which overrides any server-side default_transaction_read_only
+// session setting — this silently defeats CockroachDB
+// (default_transaction_use_follower_reads) and YugabyteDB
+// (yb_read_from_followers) follower-read routing, both of which require the
+// transaction itself to be READ ONLY. Setting ReadOnly: true here makes
+// lib/pq emit an explicit READ ONLY instead, which is the only way these two
+// mechanisms can ever activate under this driver.
+func (w *Workloader) beginTxReadOnly(ctx context.Context) (*sql.Tx, error) {
+	s := getTPCCState(ctx)
+	tx, err := s.Conn.BeginTx(ctx, &sql.TxOptions{
+		Isolation: sql.IsolationLevel(w.cfg.Isolation),
+		ReadOnly:  true,
+	})
+	return tx, err
+}
